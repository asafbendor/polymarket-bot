# Polymarket wallet (required for live trading)
POLYMARKET_PRIVATE_KEY=your_eoa_private_key_hex_here
POLYMARKET_PROXY_ADDRESS=your_proxy_wallet_address_here

# Anthropic Claude (required for political/other market analysis)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# News API (optional — improves political market estimates)
# Get free key at https://newsapi.org
NEWSAPI_KEY=your_newsapi_key_here

# GNews (optional alternative to NewsAPI)
# Get free key at https://gnews.io
GNEWS_KEY=your_gnews_key_here

# Bot parameters (optional — defaults shown)
DAILY_BUDGET=5.0
MAX_TRADE_SIZE=2.0
MAX_OPEN_POSITIONS=8
MIN_HOURS_TO_RESOLUTION=6
MAX_HOURS_TO_RESOLUTION=168
STOP_LOSS_THRESHOLD=-8.0
